# APEX NATIONAL PLATFORM — live Supabase credentials (Phase 1.5)
# Copy to .env.apex.local (gitignored via *.local).
# Loaded when APEX_ENV=1 (npm run dev:apex / npm run db:migrate:apex / Vercel Apex deploy).
# Merlinus local dev (npm run dev) ignores this file — uses .env.local only.
#
# Apply Phase 1 migration: npm run db:migrate:apex
#
# P0 — Owner seed passwords:
#   Do NOT put OWNER_SEED_PASSWORD here for production Workers.
#   Use .owner-seed.local.env (gitignored) + scripts/seed-owner-d1-remote.mjs for one-time bootstrap.
#   Production health fails if OWNER_SEED_PASSWORD* remain without ALLOW_OWNER_SEED_BOOTSTRAP=1.
#   After bootstrap: wrangler secret delete OWNER_SEED_PASSWORD; set APEX_PLATFORM_OWNER_EMAILS.

NEXT_PUBLIC_SUPABASE_URL="https://fnsuhuokwqeujepeshxh.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
APEX_DEFAULT_DEALER_ID="merlinus-default-dealer"

# Option A — full connection strings from Supabase dashboard → Database → Connection string
# SUPABASE_DATABASE_URL="postgresql://postgres.fnsuhuokwqeujepeshxh:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_DIRECT_DATABASE_URL="postgresql://postgres.fnsuhuokwqeujepeshxh:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Option B — database password only (URLs built automatically)
# SUPABASE_DB_PASSWORD="your-database-password"
# SUPABASE_DB_REGION="us-east-1"

# Required for npm run db:migrate:apex and local Prisma against Supabase:
APEX_USE_SUPABASE_DB="true"