{
  "name": "merlinus",
  "private": true,
  "version": "4.0.0",
  "scripts": {
    "dev": "next dev",
    "dev:apex": "node scripts/dev-apex.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "verify:scan-env": "node scripts/verify-scan-env.mjs",
    "validate:pre-deploy": "node scripts/validate-pre-deploy.mjs",
    "validate:pre-rollout": "tsx --import ./tests/setup/preload.mjs scripts/pre-rollout-validation.ts",
    "ready-to-deploy": "npm run validate:pre-deploy && npm run validate:pre-rollout && node scripts/validate-pre-rollout.mjs && echo Merlinus is ready for Mercedes-Benz dealership deployment && echo \"Run: npm run db:migrate-pii-safe (dry-run first)\"",
    "deploy:check": "node -e \"process.stdout.write(require('fs').readFileSync('docs/DEPLOYMENT-CHECKLIST.md','utf8'))\"",
    "build:next": "node scripts/validate-env.mjs && node scripts/prisma-with-sqlite-url.mjs generate && node scripts/migrate-deploy.mjs && next build",
    "build:opennextjs-cloudflare": "opennextjs-cloudflare build --skipNextBuild",
    "strip:opennext-secrets": "node scripts/strip-opennext-secrets.mjs",
    "verify:opennext-secrets": "node scripts/verify-opennext-no-secrets.mjs",
    "build:opennext": "node scripts/prisma-with-sqlite-url.mjs generate && npm run build:opennextjs-cloudflare && npm run strip:opennext-secrets && npm run verify:opennext-secrets",
    "build": "npm run build:next && npm run build:opennext",
    "build:cf": "npm run build",
    "build:diagnostic": "echo '=== GROK DIAGNOSTIC BUILD START ===' && npm run build:opennext 2>&1 | tee build.log && echo '=== BUILD COMPLETE - CHECKING FOR ERRORS ===' && if grep -i 'error\\|fail\\|exception' build.log; then echo 'BUILD ERRORS FOUND - SEE ABOVE'; else echo 'BUILD CLEAN'; fi && echo '=== STARTING LOCAL PREVIEW ===' && npm run preview",
    "grok-build": "npm run build:diagnostic",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/d1-migrate-diff.mjs",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:migrate:d1": "node scripts/migrate-deploy.mjs",
    "db:migrate:apex": "node scripts/migrate-deploy.mjs",
    "db:push": "node scripts/prisma-with-sqlite-url.mjs db push --accept-data-loss",
    "db:seed": "npx tsx --import ./tests/setup/preload.mjs prisma/seed.ts",
    "provision-dealer": "npx tsx --import ./tests/setup/preload.mjs scripts/provision-dealer.ts",
    "rename-test-rooftops": "npx tsx --import ./tests/setup/preload.mjs scripts/rename-test-rooftops.ts",
    "smoke:dealer-provision": "npx tsx --import ./tests/setup/preload.mjs scripts/smoke-dealer-provision.ts",
    "db:reencrypt": "npx tsx scripts/reencrypt-legacy-data.ts",
    "db:migrate-pii": "npx tsx scripts/migrate-pii-to-encrypted.ts",
    "db:migrate-pii-safe": "npx tsx scripts/migrate-pii-to-encrypted.ts --dry-run && echo \"Dry-run passed. Run npm run db:migrate-pii to execute.\"",
    "db:studio": "node scripts/prisma-with-sqlite-url.mjs studio",
    "prisma:generate": "node scripts/prisma-with-sqlite-url.mjs generate",
    "test": "tsx --import ./tests/setup/preload.mjs --test tests/unit/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "test:integration": "tsx --import ./tests/setup/preload.mjs --test --test-concurrency=1 tests/integration/**/*.test.ts",
    "test:e2e": "tsx --import ./tests/setup/preload.mjs --test tests/integration/technician-journey.test.ts",
    "setup:tesseract": "node scripts/copy-tesseract-assets.mjs",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "postinstall": "node scripts/prisma-with-sqlite-url.mjs generate && npm run setup:tesseract"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.15",
    "@prisma/adapter-better-sqlite3": "^6.19.3",
    "@prisma/adapter-d1": "^6.19.3",
    "@prisma/client": "^6.9.0",
    "@sentry/nextjs": "^10.61.0",
    "@supabase/supabase-js": "^2.110.7",
    "@vercel/blob": "^2.4.1",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "i18next": "^26.3.6",
    "jose": "^6.0.11",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.10",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.5",
    "swr": "^2.4.2",
    "tesseract.js": "^5.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@sentry/webpack-plugin": "^5.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.6.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.112.0"
  }
}
