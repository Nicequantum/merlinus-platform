# PostgreSQL (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/benz_tech?sslmode=require"

# ─── PLATFORM MODE (Merlinus default) ─────────────────────────────────────────
# merlinus (default): single-dealer Tiverton experience — D7 login, legacy session
# apex: national platform — unified login, dual-token sessions, owner scoping
# PLATFORM_MODE="merlinus"
# NEXT_PUBLIC_PLATFORM_MODE="merlinus"
# Apex local dev: npm run dev:apex (sets PLATFORM_MODE=apex in .env.apex.local)
#
# Phase 6 fortress — Postgres RLS defense-in-depth (see docs/Security-Fortress.md).
# Phase 6.2 RLS:
# - Apex: enforce ON by default (default-deny without tenant match / bypass).
# - Merlinus: soft-open unless RLS_ENABLED=true.
# - Policies require app.rls_soft_open=on for soft-open (never set on Apex).
# RLS_ENABLED="true"   # force enforce even on Merlinus
# RLS_ENABLED="false"  # soft-open only on Merlinus (ignored on Apex)

# ─── APEX NATIONAL PLATFORM (optional — Phase 1.5 Supabase) ───────────────────
# Merlinus/Tiverton local dev: leave unset — Prisma uses DATABASE_URL above unchanged.
# Apex production (Vercel): set API keys + Postgres connection (see Supabase → Settings → Database).
#
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# APEX_DEFAULT_DEALER_ID="merlinus-default-dealer"
#
# Postgres for Prisma (choose one approach):
# SUPABASE_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# — or —
# SUPABASE_DB_PASSWORD="your-database-password"
# SUPABASE_DB_REGION="us-east-1"
#
# Local Apex migration against live Supabase: copy vars to .env.apex.local and run:
#   npm run db:migrate:apex
# Enable Apex mode (loads .env.apex.local): npm run dev:apex
# APEX_ENV="1"
# Optional explicit Postgres override when not using APEX_ENV auto-routing:
# APEX_USE_SUPABASE_DB="true"

# Direct (non-pooled) PostgreSQL URL for Prisma migrations — required in production builds.
# For Neon/Prisma Postgres: use the pooled URL in DATABASE_URL and the direct host in DIRECT_URL.
# If omitted on Vercel, migrate-deploy falls back to DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/benz_tech?sslmode=require"

# ─── REQUIRED (build fails on Vercel without these) ────────────────────────────

# Session signing secret (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-long-random-string"

# ─── Phase 4: Clerk Authentication (optional during legacy JWT transition) ───
# AUTH_MODE: legacy (default) | dual | clerk
# - legacy: D7 + password JWT only (Merlinus default — no Clerk required)
# - dual:   Clerk when linked session present, else legacy JWT
# - clerk:  Clerk only (requires Clerk keys below)
# AUTH_MODE="legacy"
# NEXT_PUBLIC_AUTH_MODE="legacy"
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
# CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# AES-256 key for customer PII at rest — REQUIRED, 32 bytes / 64 hex chars
# Generate: openssl rand -hex 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
DATA_ENCRYPTION_KEY="change-me-to-64-hex-characters-for-aes-256-encryption-key-here"
# Legacy alias (pre-rename): if DATA_ENCRYPTION_KEY is unset, ENCRYPTION_KEY is used.
# ENCRYPTION_KEY="legacy-same-64-hex-key"

# HMAC key for blind-index RO search tokens — REQUIRED, 32 bytes / 64 hex chars
# Must differ from DATA_ENCRYPTION_KEY. Generate: openssl rand -hex 32
SEARCH_HMAC_KEY="change-me-to-64-hex-characters-for-search-hmac-key-here"

# ─── REQUIRED FOR RO + XENTRY SCANNING (production hard requirement) ─────────
# Without these, "Process RO" and diagnostic photo analysis fail immediately.
# Builds with NODE_ENV=production or VERCEL_ENV=production fail if either is missing.

# xAI Grok API key — SERVER ONLY (correct name: GROK_API_KEY)
# NEVER set NEXT_PUBLIC_GROK_API_KEY, NEXT_PUBLIC_XAI_API_KEY, or NEXT_PUBLIC_XAI_KEY.
# Those expose your key in the browser bundle. Builds fail if any NEXT_PUBLIC_* xAI key exists.
GROK_API_KEY="xai-your-key-here"

# Apex national platform (optional) — centralized Grok proxy for multi-dealer deployments.
# Merlinus/Tiverton single-dealer installs leave these unset; Grok calls stay direct via GROK_API_KEY.
# GROK_PROXY_API_KEY="apex-shared-proxy-secret"
# Dealer nodes mint short-lived tokens: createGrokProxyAccessToken() (HMAC, ~60s).
# Static Bearer GROK_PROXY_API_KEY is rejected unless:
# GROK_PROXY_ALLOW_STATIC_BEARER="true"
# GROK_PROXY_URL="https://apex.merlin.example"

# Vercel Blob — private photo storage for RO pages and Xentry screenshots
# Vercel setup: Project → Storage → Create Blob Store → Connect to Project
# (auto-injects BLOB_READ_WRITE_TOKEN into Production/Preview/Development env)
# Manual verify: Project → Settings → Environment Variables → BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Vercel KV / Upstash Redis — REQUIRED in Apex production for distributed rate limiting
# (missing env → login 503; store outage → in-memory fallback so login stays available).
# Setup: Vercel → Project → Storage → Create Store → Redis/Upstash → Connect to Project
# (injects KV_REST_API_URL + KV_REST_API_TOKEN, or UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN).
# Local: copy REST URL + token from the dashboard, or omit for in-memory fallback.
KV_REST_API_URL="https://your-kv-instance.upstash.io"
KV_REST_API_TOKEN="your-kv-rest-token"

# App URL (for cookies in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Live health probe for pre-rollout validation (optional — production deployment URL)
# Live pre-rollout probe (optional). Vercel project host example:
# MERLIN_BASE_URL="https://merlinus-hombre-harris-s-projects.vercel.app"
# MERLIN_BASE_URL="https://merlin.your-dealership.example"
# If Vercel Deployment Protection is on, unauthenticated /api/health returns 401 —
# open the URL while logged into Vercel, or set MERLIN_HEALTH_COOKIE / protection bypass.

# Server log verbosity: debug | info | warn | error (production default: info)
# LOG_LEVEL="info"

# Dealership branding (PDF headers, UI — set per deployment)
DEALERSHIP_DISPLAY_NAME="Mercedes-Benz of [City]"
DEALERSHIP_CODE="[DEALER_CODE]"

# Maintenance mode — blocks AI routes and shows banner (true | 1 | yes)
# MERLIN_MAINTENANCE_MODE="false"

# Build metadata (set automatically by scripts/validate-env.mjs and Vercel)
# NEXT_PUBLIC_BUILD_COMMIT=""
# NEXT_PUBLIC_BUILD_DATE=""

# Seed D7 identifiers (optional — defaults D7HARRIH / D7TECH001)
# Primary login (service manager): D7HARRIH
ADMIN_SEED_D7="D7HARRIH"
TECH_SEED_D7="D7TECH001"

# Seed account emails (optional — legacy migration only)
ADMIN_SEED_EMAIL="admin@dealership.com"
TECH_SEED_EMAIL="tech@dealership.com"

# Seed passwords — required for npm run db:seed (first-login password rotation enforced)
ADMIN_SEED_PASSWORD="your-strong-seed-password-here"
TECH_SEED_PASSWORD="your-strong-seed-password-here"

# Apex national platform owner seed (optional — only when PLATFORM_MODE=apex)
# Env only — no hard-coded owner emails/passwords in source (Phase 6.1).
# Create-only seed: existing owners are NEVER password-reset on startup/login.
# Owners log in with email; enter-dealership required for rooftop PII.
#
# P0 SECURITY — OWNER_SEED_PASSWORD* are ONE-TIME BOOTSTRAP ONLY:
#   1. Prefer local file .owner-seed.local.env (gitignored) + scripts/seed-owner-d1-remote.mjs
#   2. Or set secrets once on Worker with ALLOW_OWNER_SEED_BOOTSTRAP=1, deploy once, then DELETE
#   3. Production without ALLOW_OWNER_SEED_BOOTSTRAP: presence of OWNER_SEED_PASSWORD fails health
#   4. Never commit .owner-seed*.env — see .gitignore
#   5. Ongoing national operators: APEX_PLATFORM_OWNER_EMAILS only (not seed passwords)
#
# OWNER_SEED_EMAIL="owner@your-apex-platform.example"
# OWNER_SEED_PASSWORD="your-strong-owner-seed-password"
# OWNER_SEED_NAME="National Owner"
# OWNER_SEED_EMAIL_2="co-owner@your-apex-platform.example"
# OWNER_SEED_PASSWORD_2="your-strong-second-owner-password"
# OWNER_SEED_NAME_2="Co-Owner"
# ALLOW_OWNER_SEED_BOOTSTRAP="1"   # production one-shot only — remove after seed
#
# P1-3 MFA (optional) — when true, manager/owner/admin must enroll TOTP before PII routes
# MERLIN_MFA_ENFORCE="true"
# MERLIN_MFA_REQUIRED_ROLES="manager,owner,admin"
#
# P1-5 dual-key encryption rotation (temporary — remove PREVIOUS after reencrypt)
# DATA_ENCRYPTION_KEY_PREVIOUS="previous-key-min-32-chars................"
#
# P1-6 CSRF — enforced automatically in production; set false only for local debugging
# MERLIN_CSRF_ENFORCE="true"
#
# P3-2 premium voice realtime (Node sidecar only — not Workerd Gather)
# VOICE_REALTIME_PREMIUM="false"
#
# P3-4 self-service password recovery (public; anti-enumeration). Managers can still reset users.
# MERLIN_PASSWORD_RECOVERY_ENABLED="false"
# MERLIN_PASSWORD_RECOVERY_RETURN_TOKEN="false"  # staging/CI only — never production
#
# Explicit platform (all-rooftop) operators. Required after seed passwords are deleted.
# Without this (and without seed emails), owners with no DealerGroup membership cannot
# enter rooftops — there is no implicit "empty membership = superuser".
# APEX_PLATFORM_OWNER_EMAILS="owner@your-apex-platform.example,breakglass@your-apex-platform.example"
#
# Optional multi-rooftop demo account (apex username + two dealership memberships)
# MULTI_ROOFTOP_SEED_USERNAME="mercedes.alex.technician"
# MULTI_ROOFTOP_SEED_PASSWORD="your-strong-multi-rooftop-password"
# MULTI_ROOFTOP_SEED_NAME="Alex Multi-Rooftop"
#
# Viti Automotive Group owner (PR-G1 DealerGroup) — username login
# Default username: viti.james.gray  (override with VITI_AUTO_OWNER_USERNAME)
# VITI_AUTO_OWNER_PASSWORD="your-strong-group-owner-password"
# VITI_AUTO_OWNER_USERNAME="viti.james.gray"
# VITI_AUTO_OWNER_EMAIL="james.gray@viti.com"
# VITI_AUTO_OWNER_NAME="James Gray"
#
# Dealer provision (see docs/Apex-Dealer-Onboarding.md)
# HTTP owner API is OFF unless exactly true:
# APEX_ALLOW_HTTP_PROVISION="true"
# Production CLI/HTTP prefer a narrow DB role URL:
# PROVISION_DATABASE_URL="postgresql://…"
# APEX_PROVISION_ALLOW_APP_DB="1"   # break-glass only
# APEX_PROVISION_ALLOW_YES="1"     # required with CLI --yes
# APEX_MAX_PROVISIONS_PER_DAY="20"
# APEX_MAX_DEALERSHIPS="500"

# Usage monitoring (M28/M29)
DAILY_USAGE_LIMIT="50"
USAGE_TIMEZONE="America/New_York"

# Voice input (M18/M19) — listening timeout in ms (default 45000)
# VOICE_LISTENING_TIMEOUT_MS="45000"
# VOICE_INPUT_LANGUAGE="en-US"

# ─── Product modules (see docs/Product-Modules.md) ───────────────────────────
# Rooftop enablement is stored in DealershipModule (Manager Dashboard → Modules).
# Seed/provision enables: video_mpi, maintenance, voice_agent, loaner, parts, sales, service.
# cdk_sync stays off until CDK API credentials (PR-M7).
# core_story is NOT a module — RO warranty narrative is always on.
#
# Break-glass force-enable (comma-separated product module ids). Prefer UI toggles in prod.
# MODULES_FORCE_ENABLE="video_mpi,parts,sales,service,loaner,maintenance,voice_agent"
#
# AI Voice Agent (module: voice_agent) — Twilio Programmable Voice
# TWILIO_ACCOUNT_SID="ACxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# Local tunnel only — NEVER set true on Vercel production:
# VOICE_TWILIO_SKIP_SIGNATURE="false"
#
# Video MPI SMS delivery (optional; module: video_mpi)
# SMS_ENABLED="false"
# TWILIO_FROM_NUMBER="+15551234567"
#
# Public URL for Twilio webhook action URLs and customer video links
# NEXT_PUBLIC_APP_URL="https://your-production-host.example"
#
# Video inspection limits (optional)
# VIDEO_INSPECTION_MAX_MB="80"
# VIDEO_INSPECTION_MAX_DURATION_SEC="180"

# Re-encryption batch size (M26)
# REENCRYPT_BATCH_SIZE="100"

# Trusted proxy hops for rate-limit IP (M14) — Vercel default 1
# TRUSTED_PROXY_HOPS="1"

# Sentry error monitoring (required for validate:pre-deploy / ready-to-deploy)
NEXT_PUBLIC_SENTRY_DSN="https://your-key@o0.ingest.sentry.io/0"
# Optional override (defaults to VERCEL_ENV / NODE_ENV)
# SENTRY_ENVIRONMENT="production"
